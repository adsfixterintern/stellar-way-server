{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "esnext",

    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "src/types"],

    "esModuleInterop": true,

    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },

  "include": ["src/**/*", "src/types/*.d.ts"]
}